# Kronos Hub environment template
#
# By default the hub looks for these directories under the repository root:
# - ai-hedge-fund-main
# - TradingAgents-main
# - Kronos-master
#
# Uncomment the path variables only if your subprojects live elsewhere.

# KRONOS_HUB_AI_HEDGE_FUND_PATH=F:\path\to\ai-hedge-fund-main
# KRONOS_HUB_TRADINGAGENTS_PATH=F:\path\to\TradingAgents-main
# KRONOS_HUB_KRONOS_PATH=F:\path\to\Kronos-master

# Optional: point each subproject at its own Python interpreter.
# This is the recommended setup when dependencies differ between projects.
# KRONOS_HUB_AI_HEDGE_FUND_PYTHON=F:\kronos\.venv-aihf\Scripts\python.exe
# KRONOS_HUB_TRADINGAGENTS_PYTHON=F:\kronos\.venv-tradingagents\Scripts\python.exe
# KRONOS_HUB_KRONOS_PYTHON=F:\kronos\.venv-kronos\Scripts\python.exe

KRONOS_HUB_HOST=127.0.0.1
KRONOS_HUB_PORT=8010

# Optional provider and data keys
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
ALPHA_VANTAGE_API_KEY=
FINANCIAL_DATASETS_API_KEY=
HUGGINGFACE_HUB_TOKEN=
